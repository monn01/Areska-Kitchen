// Areska Kitchen — Prisma schema
// Fase 1: model disiapkan untuk kebutuhan Fase 2/3, landing page pakai data statis (lib/data.ts).
// Fase 2: model diaktifkan untuk katalog dinamis + ordering. Lihat PRD.md §10-11 dan TASKPLAN.md FASE 2.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductCategory {
  NASI_KOTAK
  PRASMANAN
  SNACK_BOX
  PEMPEK_LAINNYA
}

/// Jenis acara yang cocok untuk produk ini — dipakai untuk filter "Occasion" di katalog
/// (referensi desain Figma). Ditandai admin manual per produk, mirip pola isPopular.
enum ProductOccasion {
  MEETING
  WEDDING
  BIRTHDAY
  GATHERING
}

model Product {
  id          String            @id @default(cuid())
  category    ProductCategory
  name        String
  description String
  /// Harga jual definitif per unit (dipakai di cart/checkout) — pengganti priceMin/priceMax
  /// dari Fase 1 yang cuma untuk tampilan kisaran, tidak bisa dipakai transaksi nyata.
  price       Int
  imageUrl    String?
  isActive    Boolean           @default(true)
  /// Ditandai admin untuk tampil di "Paket Populer" (landing page) & badge "Populer" di
  /// katalog — bukan dihitung otomatis dari penjualan, murni kurasi manual dulu.
  isPopular   Boolean           @default(false)
  occasions   ProductOccasion[] @default([])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  orderItems OrderItem[]

  @@index([category])
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  role       String?
  quote      String
  isFeatured Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Client {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  /// Baris marquee "Dipercaya Oleh" (1 = atas/kiri-ke-kanan, 2 = bawah/kanan-ke-kiri) — lihat
  /// components/sections/TrustedBy.tsx yang sudah dibangun untuk struktur data ini di Fase 1.
  row       Int      @default(1)
  isVisible Boolean  @default(false) // baru true setelah izin resmi didapat (PRD §16.1)
  createdAt DateTime @default(now())
}

// --- Fase 2 (E-commerce/Ordering) ---

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
}

model Order {
  id              String      @id @default(cuid())
  customerName    String
  customerPhone   String
  /// Alamat/lokasi pengiriman acara — penting untuk katering, bukan sekadar retail shipping.
  deliveryAddress String?
  deliveryLat     Float?
  deliveryLng     Float?
  /// Ongkir hasil hitung jarak (Phase 6) — disimpan terpisah dari totalAmount supaya rincian
  /// tetap terlihat jelas di detail order admin.
  deliveryFee     Int         @default(0)
  /// Tanggal acara/pengiriman diminta pelanggan (beda dari createdAt = kapan order dibuat).
  eventDate       DateTime?
  /// Jam pengantaran diminta, format "HH:mm" (WIB), dalam rentang jam operasional.
  deliveryTime    String?
  notes           String?
  discountAmount  Int         @default(0)
  voucher         Voucher?    @relation(fields: [voucherId], references: [id])
  voucherId       String?
  /// subtotal item + deliveryFee - discountAmount
  totalAmount     Int
  status          OrderStatus @default(PENDING)
  isCustomEvent   Boolean     @default(false) // prasmanan/event besar, butuh konfirmasi manual (PRD §7)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items       OrderItem[]
  transaction Transaction?
  user        User?       @relation(fields: [userId], references: [id])
  userId      String?

  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  /// Snapshot harga saat order dibuat — sengaja tidak selalu ambil dari Product.price
  /// supaya perubahan harga produk di kemudian hari tidak mengubah riwayat order lama.
  priceEach Int
}

model Transaction {
  id            String    @id @default(cuid())
  order         Order     @relation(fields: [orderId], references: [id])
  orderId       String    @unique
  amount        Int
  paymentMethod String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  // Midtrans-specific tracking (Fase 2 Phase 6) — disiapkan sejak awal supaya tidak perlu
  // migrasi tambahan saat integrasi payment gateway dikerjakan.
  midtransOrderId       String? @unique
  midtransTransactionId String? @unique
  midtransStatus        String? // raw transaction_status dari Midtrans: settlement/pending/deny/expire/cancel
  snapToken             String?
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  /// Nomor WhatsApp dinormalisasi (format 62xxx) — jadi identitas login alternatif selain
  /// email ("Daftar dengan WhatsApp"), makanya harus unik seperti email.
  phone     String?  @unique
  /// Hash password (bcrypt) untuk login credentials — admin (wajib), pelanggan email/WA (wajib),
  /// null untuk akun yang daftar/masuk lewat Google (tidak ada password untuk dibobol).
  password  String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  orders              Order[]
  addresses           Address[]
  passwordResetTokens PasswordResetToken[]
}

/// Token sekali-pakai untuk alur lupa password (fitur baru: Sesi 5). Dibuat saat user minta
/// reset, dihapus setelah dipakai atau kedaluwarsa — tidak pernah simpan password baru di sini.
model PasswordResetToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Alamat tersimpan milik pelanggan yang punya akun (fitur #11 — multi-alamat). Guest checkout
/// tidak menyentuh model ini, tetap isi alamat manual per order seperti biasa.
model Address {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  label     String // "Rumah", "Kantor", dst — bebas diisi pelanggan
  address   String
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

/// Voucher/kode promo (fitur #10) — sengaja dikerjakan setelah Payment (Phase 7) selesai,
/// bukan blocking checkout dasar.
model Voucher {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Int
  minOrder      Int?
  validFrom     DateTime?
  validUntil    DateTime?
  usageLimit    Int?
  usageCount    Int          @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  orders Order[]
}

/// Setting aplikasi — single-row (selalu di-query lewat findFirst, di-upsert lewat admin
/// settings page). Dibuat sebagai kolom bertipe eksplisit (bukan key-value generik) karena
/// jumlah setting-nya kecil dan tetap — lebih type-safe untuk dipakai di banyak tempat
/// (checkout, cutoff validation, kalkulasi ongkir).
model AppSetting {
  id String @id @default(cuid())

  /// Format "HH:mm" (WIB) — order untuk H+1 harus masuk sebelum jam ini (fitur #3, CRITICAL).
  orderCutoffTime String @default("20:00")

  /// Titik lokasi dapur/toko untuk hitung jarak ongkir (fitur #13) — default estimasi pusat
  /// kota Pangkalpinang, BUTUH INPUT KLIEN: koordinat asli dapur/toko.
  kitchenLat Float @default(-2.1316)
  kitchenLng Float @default(106.1169)

  /// Radius area layanan (km) dan tarif ongkir per km — BUTUH INPUT KLIEN untuk angka final.
  deliveryRadiusKm Float @default(15)
  deliveryFeePerKm Int   @default(3000)

  /// Toggle darurat — nonaktifkan sementara checkout retail dari dashboard admin kalau dapur
  /// kewalahan, tanpa perlu deploy ulang (pengganti batas kapasitas harian yang belum dibangun).
  retailCheckoutEnabled Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// --- Fase 3 (Dashboard Admin / Keuangan) ---

model FinancialRecord {
  id              String   @id @default(cuid())
  periodStart     DateTime
  periodEnd       DateTime
  modal           Int
  operationalCost Int      @default(0)
  grossProfit     Int      @default(0) // dihitung dari agregat Transaction
  netProfit       Int      @default(0) // grossProfit - operationalCost
  notes           String?
  createdAt       DateTime @default(now())
}
