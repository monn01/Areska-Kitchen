# Local dev: matches docker-compose.yml. Production: Neon connection string.
DATABASE_URL="postgresql://areska:areska_dev_password@localhost:5433/areska_kitchen?schema=public"

# Auth.js (NextAuth) — generate with `npx auth secret` or `openssl rand -base64 32`
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Midtrans (sandbox keys for development — see https://dashboard.sandbox.midtrans.com)
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# Google OAuth ("Lanjutkan dengan Google" di login/daftar) — buat di
# https://console.cloud.google.com/apis/credentials, authorized redirect URI:
# <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (kirim email reset password) — https://resend.com, gratis s/d 3.000 email/bulan.
# Kalau kosong, link reset cuma dicatat ke log server (fallback dev), belum benar-benar
# terkirim ke pelanggan.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Areska Kitchen <no-reply@areskakitchen.local>"
